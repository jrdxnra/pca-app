rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isMember(accountId) {
      return exists(/databases/$(database)/documents/memberships/$(accountId + "_" + request.auth.uid));
    }

    function getUserRole(accountId) {
      return get(/databases/$(database)/documents/memberships/$(accountId + "_" + request.auth.uid)).data.role;
    }

    function isOwner(accountId) {
      return getUserRole(accountId) == 'owner';
    }

    function isTrainer(accountId) {
      return getUserRole(accountId) in ['owner', 'trainer'];
    }

    function isMasterUser() {
      return request.auth != null && request.auth.uid == 'DuRPTA63JJOicaDVeF69XhpkTNh2';
    }

    // 1. Memberships: Users can read their own memberships
    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow read: if isAuthenticated() && isOwner(resource.data.accountId);
      
      // Create: Only owners can invite new members (via invitations)
      allow create: if false;
      
      // Delete: Only owners can remove members
      allow delete: if isAuthenticated() && isOwner(resource.data.accountId);
    }

    // 2. Invitations: Track pending coach invitations
    match /invitations/{invitationId} {
      // Anyone can read their own invitations
      allow read: if isAuthenticated() && (resource.data.invitedEmail == request.auth.token.email || isOwner(resource.data.accountId));
      
      // Owners can create invitations
      allow create: if isAuthenticated() && isOwner(request.resource.data.accountId) && 
        request.resource.data.status == 'pending' &&
        request.resource.data.role in ['trainer', 'client'];
      
      // Owners/invited users can update (accept/decline)
      allow update: if isAuthenticated() && (isOwner(resource.data.accountId) || resource.data.invitedEmail == request.auth.token.email);
      
      // Only owners can delete
      allow delete: if isAuthenticated() && isOwner(resource.data.accountId);
    }

    // 3. Accounts: Users can read accounts they are members of
    match /accounts/{accountId} {
      allow read: if isAuthenticated() && (isMember(accountId) || accountId == 'master');
      allow create: if false; // Only via backend provisioning
    }

    // 4. Multi-Tenant Collections (The Silos)
    match /{collectionName}/{docId} {
      // Read: Trainers and clients can read their account's data
      allow read: if isAuthenticated() && 
        !(collectionName in ['accounts', 'memberships', 'users', 'googleCalendarTokens', 'invitations']) &&
        (isMasterUser() || resource.data.ownerId == 'master' || isMember(resource.data.ownerId));
      
      // Write: Only trainers and owners can write
      allow write: if isAuthenticated() && 
        !(collectionName in ['accounts', 'memberships', 'users', 'googleCalendarTokens', 'invitations']) &&
        (isMasterUser() || isTrainer(resource.data.ownerId) || isTrainer(request.resource.data.ownerId));
    }

    // 5. User-Specific data (personal tokens, preferences)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 6. Calendar Tokens: User-scoped, not globally readable
    match /users/{userId}/googleCalendarTokens/{tokenId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Legacy calendar tokens (for backward compatibility)
    match /googleCalendarTokens/{tokenId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}

